OPENAI_API_KEY=
OPENAI_BASE_URL=

# Local MongoDB: mongodb://localhost:27017
# MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=job_matcher

PINECONE_API_KEY=
PINECONE_INDEX_NAME=
# Optional: using the index host avoids an extra index lookup.
PINECONE_INDEX_HOST=

EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
